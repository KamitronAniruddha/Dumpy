{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A love quiz created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctOptionIndex": { "type": "number" }
            }
          }
        },
        "shortCode": { "type": "string" },
        "type": { "type": "string", "enum": ["standard", "secret-dump"] },
        "theme": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "creatorId", "questions"]
    },
    "Response": {
      "title": "Response",
      "description": "A response to a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "respondentName": { "type": "string" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionIndex": { "type": "number" },
              "selectedOptionIndex": { "type": "number" }
            }
          }
        },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["quizId", "respondentName", "answers"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quizzes created by users"
    },
    "/quizzes/{quizId}/responses/{responseId}": {
      "schema": "Response",
      "description": "Responses to a specific quiz"
    }
  }
}
